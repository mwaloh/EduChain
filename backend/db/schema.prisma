// Prisma schema for EduChain analytics database
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  googleId      String?   @unique
  walletAddress String?   @unique // Blockchain address (optional, can be added later)
  name          String?
  emailVerified DateTime?
  image         String?
  role          String    @default("student") // "student", "employer", "institution_admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  
  @@index([email])
  @@index([googleId])
  @@index([walletAddress])
}

model Account {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String    // "google", "metamask", etc.
  providerAccountId String
  type          String    // "oauth"
  scope         String?
  token_type    String?
  access_token  String?
  refresh_token String?
  expires_at    Int?
  createdAt     DateTime  @default(now())
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken  String    @unique
  expires       DateTime
  createdAt     DateTime  @default(now())
  
  @@index([userId])
}

model Institution {
  id            String    @id @default(cuid())
  address       String    @unique // Blockchain address
  name          String
  metadataURI   String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  credentials   Credential[]
  verificationLogs VerificationLog[]
  
  @@index([address])
}

model InstitutionSignup {
  id                  String    @id @default(cuid())
  institutionName     String
  adminEmail          String    @unique
  adminName           String
  domain              String
  passwordHash        String
  verificationToken   String    @unique
  status              String    @default("pending") // "pending", "verified", "approved", "rejected"
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@index([adminEmail])
  @@index([verificationToken])
  @@index([status])
}

model Credential {
  id            String    @id @default(cuid())
  tokenId       BigInt    @unique // NFT token ID
  studentAddress String   // Blockchain address
  studentHash   String    // SHA256 hash for privacy
  ipfsCid       String
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  
  issuedOn      DateTime
  expiresOn     DateTime?
  revoked       Boolean   @default(false)
  revocationReason String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  verificationLogs VerificationLog[]
  claimTokens      ClaimToken[]
  accessTokens     AccessToken[]
  
  @@index([tokenId])
  @@index([studentAddress])
  @@index([institutionId])
}

model VerificationLog {
  id              String      @id @default(cuid())
  verifierAddress String      // Employer/verifier blockchain address
  tokenId         BigInt      // NFT token ID
  credentialId    String
  credential      Credential  @relation(fields: [credentialId], references: [id])
  institutionId   String
  institution     Institution @relation(fields: [institutionId], references: [id])
  
  timestamp       DateTime    @default(now())
  status          String      // "valid", "revoked", "expired", "invalid"
  revoked         Boolean     @default(false)
  blockchainTxHash String?    // Transaction hash if logged on-chain
  
  @@index([verifierAddress])
  @@index([tokenId])
  @@index([timestamp])
  @@index([status])
}

model Analytics {
  id              String      @id @default(cuid())
  date            DateTime    @unique // Daily aggregated stats
  totalCredentials BigInt     @default(0)
  totalVerifications BigInt   @default(0)
  revokedCount    BigInt      @default(0)
  expiredCount    BigInt      @default(0)
  newInstitutions BigInt      @default(0)
  
  createdAt       DateTime    @default(now())
  
  @@index([date])
}

model FraudAttempt {
  id              String      @id @default(cuid())
  tokenId         BigInt
  verifierAddress String
  attemptedStatus String      // What they tried to verify as
  actualStatus    String      // Actual status from blockchain
  timestamp       DateTime    @default(now())
  
  @@index([tokenId])
  @@index([timestamp])
}

model AuditLog {
  id                  String      @id @default(cuid())
  timestamp           DateTime    @default(now())
  action              String      // "CREDENTIAL_MINTED", "CREDENTIAL_VERIFIED", etc.
  userAddress         String      // Blockchain address of user performing action
  userRole            String      // "student", "institution_admin", "owner", "verifier"
  details             String      // JSON string with action details
  status              String      // "success" or "failed"
  ipAddress           String?     // Optional: IP address for web actions
  userAgent           String?     // Optional: Browser/client info
  relatedCredentialId BigInt?     // Optional: Link to credential
  relatedVerificationId Int?      // Optional: Link to verification
  
  @@index([timestamp])
  @@index([action])
  @@index([userAddress])
  @@index([status])
  @@index([relatedCredentialId])
}

model ClaimToken {
  id            String    @id @default(cuid())
  token         String    @unique // Unique claim token (UUID)
  credentialId  String
  credential    Credential @relation(fields: [credentialId], references: [id])
  studentEmail  String    // Email address for notifications
  studentName   String?   // Optional student name for personalization
  claimed       Boolean   @default(false)
  claimedAt     DateTime?
  claimedBy     String?   // Address that claimed it
  expiresAt     DateTime  // Token expiration
  createdAt     DateTime  @default(now())
  
  @@index([token])
  @@index([studentEmail])
  @@index([claimed])
  @@index([expiresAt])
}

model AccessToken {
  id            String    @id @default(cuid())
  token         String    @unique // Unique share token (UUID)
  credentialId  String
  credential    Credential @relation(fields: [credentialId], references: [id])
  creatorAddress String   // Student's wallet address
  expiresAt     DateTime  // Token expiration
  viewCount     Int       @default(0) // Track how many times viewed
  limited       Boolean   @default(false) // If true, only works once
  createdAt     DateTime  @default(now())
  
  @@index([token])
  @@index([creatorAddress])
  @@index([expiresAt])
}

model BulkImportJob {
  id            String    @id @default(cuid())
  jobId         String    @unique // Unique job identifier
  institutionAddress String // Institution performing the import
  status        String    @default("pending") // "pending", "processing", "completed", "failed"
  totalRows     Int       // Total rows in CSV
  processedRows Int       @default(0) // Rows processed so far
  successCount  Int       @default(0) // Successfully imported
  failureCount  Int       @default(0) // Failed rows
  errors        String    @default("[]") // JSON array of error objects
  createdAt     DateTime  @default(now())
  completedAt   DateTime? // When job finished
  
  @@index([jobId])
  @@index([institutionAddress])
  @@index([status])
  @@index([createdAt])
}

model CredentialAudit {
  id                    String    @id @default(cuid())
  action                String    // "BULK_IMPORT", "ISSUED", "REVOKED", etc.
  studentAddress        String    // Student's wallet address
  institutionAddress    String    // Institution's wallet address
  metadata              String?   // JSON string with metadata
  transactionHash       String?   // Blockchain transaction hash
  details               String?   // Additional details
  createdAt             DateTime  @default(now())
  
  @@index([action])
  @@index([studentAddress])
  @@index([institutionAddress])
  @@index([createdAt])
}

