    "multer": "^2.1.1",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "prisma": "^5.19.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.2"
