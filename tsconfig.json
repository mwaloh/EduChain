{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["hardhat-env.d.ts", "scripts/**/*.ts", "test/**/*.ts"],
  "exclude": [
    "node_modules",
    "scripts/create-test-users.ts",
    "scripts/verify-onboarding.ts"
  ]
}